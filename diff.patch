+def cross_entropy(logits, y, ignore_index=-100, weight: Optional[List[float]] = None):
+   """
+   重み付きクロスエントロピー損失
+   weight: [w_neg, w_pos] の形で渡すと，
+           torch.Tensor に変換して F.cross_entropy の weight に設定します
+   """
+   logits = logits.view(-1, logits.shape[-1])
+   y = y.view(-1)
+   if weight is not None:
+       # デバイス合わせて Tensor 化
+       device = logits.device
+       weight_tensor = torch.tensor(weight, device=device, dtype=logits.dtype)
+   else:
+       weight_tensor = None
+   return F.cross_entropy(
+       logits, y,
+       weight=weight_tensor,
+       ignore_index=ignore_index,
+       label_smoothing=0.01
+   )
