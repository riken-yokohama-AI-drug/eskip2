+def binary_auc(logits, y):
+    # 1) flatten batch×… を 2D logits, 1D labels に
+    logits = logits.view(-1, logits.shape[-1]).detach()
+    y      = y.view(-1).detach()
+    # 2) クラス1のスコアをそのまま使う（softmax は不要）
+    scores = logits[:, 1].cpu().numpy()
+    y_np   = y.cpu().numpy()
+    # 3) 0/1 両方が揃っていないバッチは定義できないので nan
+    if len(np.unique(y_np)) < 2:
+        return float("nan")
+    # 4) average 引数なしで計算
+    return roc_auc_score(y_np, scores)
+
 
